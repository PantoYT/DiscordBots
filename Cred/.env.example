# Copy to .env and fill in. NEVER commit .env.
DISCORD_TOKEN=your-bot-token-here
OWNER_ID=your-discord-user-id

# Amberfall project root (Cred reads PROGRESS.md + preview/milestones for reports).
AMBERFALL_DIR=/home/youruser/amberfall

REPORT_INTERVAL_MIN=30
EMBED_COLOR=0xFFB13B

# Optional: post to a channel id instead of DMing the owner.
REPORT_CHANNEL_ID=
